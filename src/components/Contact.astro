---
import { portfolioData } from '../data/portfolio';

const { email, location } = portfolioData.personalInfo;
const socials = portfolioData.socials;
---

<section id="contact" class="section">
  <div class="container">
    <div class="contact-grid">
      <!-- Info Column -->
      <div class="info-col reveal">
        <div class="badge">Contact</div>
        <h2 class="section-title">Let's build something together</h2>
        <p class="contact-desc">
          Have an exciting project, freelance opportunity, or internship position? Feel free to reach out. I'll get back to you as soon as possible.
        </p>

        <div class="contact-methods">
          <div class="method-item">
            <div class="method-icon glass">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            </div>
            <div>
              <span class="method-label">Email</span>
              <a href={`mailto:${email}`} class="method-value link-hover">{email}</a>
            </div>
          </div>

          <div class="method-item">
            <div class="method-icon glass">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div>
              <span class="method-label">Location</span>
              <span class="method-value">{location}</span>
            </div>
          </div>
        </div>

        <!-- Social Connections -->
        <div class="social-row">
          {socials.github && (
            <a href={socials.github} target="_blank" rel="noopener noreferrer" class="social-icon-btn glass" aria-label="GitHub Profile">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
            </a>
          )}
          {socials.linkedin && (
            <a href={socials.linkedin} target="_blank" rel="noopener noreferrer" class="social-icon-btn glass" aria-label="LinkedIn Profile">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            </a>
          )}
          {socials.twitter && (
            <a href={socials.twitter} target="_blank" rel="noopener noreferrer" class="social-icon-btn glass" aria-label="Twitter Profile">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
            </a>
          )}
        </div>
      </div>

      <!-- Form Column -->
      <div class="form-col reveal reveal-delay-2">
        <div id="form-container" class="form-wrapper glass">
          <form id="contact-form" novalidate>
            <div class="form-grid">
              <div class="input-group">
                <label for="form-name">Name</label>
                <input type="text" id="form-name" name="name" required placeholder="John Doe" />
                <span class="error-msg" id="name-error">Please enter your name</span>
              </div>
              
              <div class="input-group">
                <label for="form-email">Email</label>
                <input type="email" id="form-email" name="email" required placeholder="john@example.com" />
                <span class="error-msg" id="email-error">Please enter a valid email address</span>
              </div>
            </div>

            <div class="input-group">
              <label for="form-subject">Subject</label>
              <input type="text" id="form-subject" name="subject" required placeholder="Project collaboration proposal" />
              <span class="error-msg" id="subject-error">Please enter a subject</span>
            </div>

            <div class="input-group">
              <label for="form-message">Message</label>
              <textarea id="form-message" name="message" required rows="5" placeholder="Tell me more details about your inquiry..."></textarea>
              <span class="error-msg" id="message-error">Please write a message</span>
            </div>

            <button type="submit" class="btn btn-primary submit-btn">
              Send Message
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            </button>
          </form>
        </div>
        
        <!-- Success State Container (hidden by default) -->
        <div id="success-container" class="success-wrapper glass text-center" style="display: none;">
          <div class="success-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 8 12 12 14 14"></polyline><path d="M12 2a10 10 0 1 0 10 10"></path><path d="m16 8-6 6-2-2"></path></svg>
          </div>
          <h3 class="success-title">Message sent successfully!</h3>
          <p class="success-desc">Thank you for reaching out. Sahal will review your message and respond shortly.</p>
          <button id="reset-form-btn" class="btn btn-secondary">Send another message</button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.25fr;
    gap: 4rem;
    align-items: flex-start;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .contact-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .method-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .method-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
  }

  .method-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    font-weight: 600;
  }

  .method-value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .link-hover {
    color: var(--primary);
    position: relative;
  }
  
  .link-hover::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-fast) ease;
  }

  .link-hover:hover::after {
    transform: scaleX(1);
  }

  /* Social row */
  .social-row {
    display: flex;
    gap: 0.75rem;
  }

  .social-icon-btn {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    transition: all var(--transition-fast);
  }

  .social-icon-btn:hover {
    color: var(--primary);
    border-color: var(--primary);
    transform: translateY(-3px);
    background-color: var(--primary-light);
  }

  /* Form and Success Containers */
  .form-wrapper, .success-wrapper {
    padding: 2.5rem;
    border-radius: var(--radius-lg);
  }

  .success-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 400px;
  }

  .success-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: var(--primary-light);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    animation: scaleUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes scaleUp {
    from {
      transform: scale(0.8);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .success-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .success-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    max-width: 400px;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  /* Input fields */
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 600px) {
    .form-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .input-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .input-group input, .input-group textarea {
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    background-color: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .input-group input:focus, .input-group textarea:focus {
    border-color: var(--primary);
    background-color: var(--bg-secondary);
  }

  .submit-btn {
    width: 100%;
    margin-top: 1rem;
  }

  /* Client Side Form Validation styles */
  .input-group.invalid input, .input-group.invalid textarea {
    border-color: #ef4444;
  }

  .error-msg {
    display: none;
    font-size: 0.75rem;
    color: #ef4444;
    font-weight: 500;
  }

  .input-group.invalid .error-msg {
    display: block;
  }
</style>

<script>
  const setupForm = () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const formContainer = document.getElementById('form-container');
    const successContainer = document.getElementById('success-container');
    const resetBtn = document.getElementById('reset-form-btn');

    if (!form || !formContainer || !successContainer || !resetBtn) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      let isValid = true;
      const inputs = form.querySelectorAll('input[required], textarea[required]');

      inputs.forEach(input => {
        const inp = input as HTMLInputElement | HTMLTextAreaElement;
        const group = inp.parentElement;

        if (!group) return;

        // Custom validation check
        if (!inp.value.trim()) {
          group.classList.add('invalid');
          isValid = false;
        } else if (inp.type === 'email' && !validateEmail(inp.value)) {
          group.classList.add('invalid');
          isValid = false;
        } else {
          group.classList.remove('invalid');
        }
      });

      if (isValid) {
        // Show loading state or fake submission
        const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
        submitBtn.disabled = true;
        submitBtn.innerText = 'Sending...';

        setTimeout(() => {
          // Success sequence
          formContainer.style.display = 'none';
          successContainer.style.display = 'flex';
          form.reset();
          submitBtn.disabled = false;
          submitBtn.innerHTML = `Send Message <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>`;
        }, 1000);
      }
    });

    // Clear validation states on input
    form.querySelectorAll('input, textarea').forEach(input => {
      input.addEventListener('input', () => {
        const group = input.parentElement;
        if (group && group.classList.contains('invalid')) {
          group.classList.remove('invalid');
        }
      });
    });

    // Reset Form button
    resetBtn.addEventListener('click', () => {
      successContainer.style.display = 'none';
      formContainer.style.display = 'block';
    });
  };

  const validateEmail = (email: string) => {
    const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return re.test(email);
  };

  // Run on load
  setupForm();
  // Run on page transition swap
  document.addEventListener('astro:after-swap', setupForm);
</script>
