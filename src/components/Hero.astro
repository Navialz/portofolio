---
import { portfolioData } from '../data/portfolio';

const { name, role, subrole, bio } = portfolioData.personalInfo;
---

<section id="hero" class="hero-section">
  <div class="grid-bg"></div>
  
  <div class="container hero-container">
    <div class="hero-content reveal">
      <div class="badge">
        <span class="pulse-dot"></span>
        Available for Freelance & Internships
      </div>
      
      <h1 class="hero-title">
        Creative developer crafting <span class="highlight-text">thoughtful digital systems</span>
      </h1>
      
      <p class="hero-bio">
        Hi, I'm <strong class="name-text">{name}</strong>, a <span class="role-text">{role}</span>. {subrole}. {bio}
      </p>

      <div class="hero-actions">
        <a href="#projects" class="btn btn-primary">
          Explore Projects
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
        <a href="#contact" class="btn btn-secondary">Get in touch</a>
      </div>
    </div>
  </div>
</section>

<!-- Scroll Indicator — fixed to viewport, independent of section -->
<a id="scroll-indicator" href="#about" class="scroll-down" aria-label="Scroll to about section">
  <div class="mouse">
    <div class="wheel"></div>
  </div>
  <span class="scroll-text">Scroll to explore</span>
</a>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding-top: 8rem;
    padding-bottom: 4rem;
    overflow: hidden;
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .hero-content {
    max-width: 800px;
    margin-bottom: 4rem;
  }

  /* Pulse Dot Animation for Badge */
  .pulse-dot {
    width: 6px;
    height: 6px;
    background-color: var(--primary);
    border-radius: 50%;
    position: relative;
  }

  .pulse-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1px solid var(--primary);
    animation: pulse 1.8s cubic-bezier(0.24, 0, 0.38, 1) infinite;
  }

  @keyframes pulse {
    0% {
      transform: scale(0.8);
      opacity: 0.8;
    }
    100% {
      transform: scale(2.4);
      opacity: 0;
    }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-top: 1rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }
  }

  .highlight-text {
    background: linear-gradient(120deg, var(--primary) 0%, var(--primary-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    position: relative;
  }

  .hero-bio {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .name-text {
    color: var(--text-primary);
    font-weight: 600;
  }

  .role-text {
    font-weight: 500;
    color: var(--primary);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 280px;
      margin: 0 auto;
    }
    .hero-actions .btn {
      width: 100%;
    }
  }

  /* Animated Scroll Down Indicator — fixed to viewport */
  .scroll-down {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 1;
    transition: color var(--transition-fast), opacity 0.5s ease, visibility 0.5s ease;
    visibility: visible;
  }

  .scroll-down.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .scroll-down:hover {
    color: var(--text-primary);
  }

  .mouse {
    width: 24px;
    height: 38px;
    border: 2px solid var(--text-muted);
    border-radius: var(--radius-full);
    display: flex;
    justify-content: center;
    padding-top: 6px;
    transition: border-color var(--transition-fast);
  }

  .scroll-down:hover .mouse {
    border-color: var(--text-primary);
  }

  .wheel {
    width: 3px;
    height: 7px;
    background-color: var(--text-muted);
    border-radius: var(--radius-full);
    animation: scroll-wheel 1.6s ease-in-out infinite;
  }

  .scroll-down:hover .wheel {
    background-color: var(--text-primary);
  }

  @keyframes scroll-wheel {
    0% {
      transform: translateY(0);
      opacity: 1;
    }
    50% {
      transform: translateY(8px);
      opacity: 0.4;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .scroll-text {
    opacity: 0.8;
  }
</style>

<script>
  const setupScrollIndicator = () => {
    const indicator = document.getElementById('scroll-indicator');
    if (!indicator) return;

    // Remove any previously attached listener to avoid duplicates
    const handler = () => {
      if (window.scrollY > 60) {
        indicator.classList.add('hidden');
      } else {
        indicator.classList.remove('hidden');
      }
    };

    window.addEventListener('scroll', handler, { passive: true });
    // Run once on init to handle the case where page loads already scrolled
    handler();
  };

  setupScrollIndicator();
  document.addEventListener('astro:after-swap', setupScrollIndicator);
</script>
