---
import { portfolioData } from '../data/portfolio';

const { name } = portfolioData.personalInfo;
const currentYear = new Date().getFullYear();
---

<footer class="glass">
  <div class="container footer-container">
    <!-- Branding -->
    <div class="footer-brand">
      <a href="#hero" class="logo" aria-label="Home">
        <span class="logo-mark">
          <img src="/assets/avatar.jpg" alt="Sahal Fatih" class="logo-avatar" />
        </span>
        <span class="logo-name">{name}</span>
      </a>
      <p class="brand-desc">Student & Fullstack Developer crafting clean, high-performance web products.</p>
    </div>

    <!-- Quick links -->
    <div class="footer-links-group">
      <div class="footer-links-col">
        <span class="col-title">Navigation</span>
        <a href="#hero">Home</a>
        <a href="#about">About</a>
        <a href="#skills">Skills</a>
        <a href="#projects">Projects</a>
      </div>
      <div class="footer-links-col">
        <span class="col-title">Other</span>
        <a href="#journey">Journey</a>
        <a href="#contact">Contact</a>
        <a href="https://github.com" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
  </div>

  <!-- Bottom copyrights -->
  <div class="footer-bottom">
    <div class="container bottom-container">
      <p class="copyright">&copy; {currentYear} {name}. All rights reserved.</p>
      <p class="credits">Designed & Built with Astro</p>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--glass-border);
    margin-top: auto;
    background-color: var(--bg-secondary);
    transition: background-color var(--transition-normal), border-color var(--transition-normal);
  }

  .footer-container {
    padding-top: 4.5rem;
    padding-bottom: 4.5rem;
    display: flex;
    justify-content: space-between;
    gap: 4rem;
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      gap: 3rem;
      padding-top: 3rem;
      padding-bottom: 3rem;
    }
  }

  .footer-brand {
    max-width: 320px;
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1rem;
    text-decoration: none;
  }

  .logo-mark {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .logo-avatar {
    display: block;
    width: 30px;
    min-width: 30px;
    max-width: 30px;
    height: 30px;
    min-height: 30px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center;
    border: 2px solid var(--border-color);
    transition: border-color var(--transition-fast);
    flex-shrink: 0;
  }

  .logo:hover .logo-avatar {
    border-color: var(--primary);
  }

  .logo:hover .logo-mark {
    transform: scale(1.06);
  }

  .logo-name {
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }

  .logo:hover .logo-name {
    color: var(--primary);
  }

  .brand-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .footer-links-group {
    display: flex;
    gap: 4rem;
  }

  @media (max-width: 480px) {
    .footer-links-group {
      gap: 2.5rem;
    }
  }

  .footer-links-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .col-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .footer-links-col a {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .footer-links-col a:hover {
    color: var(--primary);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
  }

  .bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .bottom-container {
      flex-direction: column;
      text-align: center;
      gap: 0.5rem;
    }
  }
</style>
