---
import { portfolioData } from '../data/portfolio';

const journey = portfolioData.journey;
---

<section id="journey" class="section bg-dim">
  <div class="container">
    <div class="text-center reveal">
      <div class="badge">Timeline</div>
      <h2 class="section-title">My journey so far</h2>
      <p class="section-subtitle">A chronological summary of my professional experience, education, and notable engineering achievements.</p>
    </div>

    <div class="timeline">
      {journey.map((item, idx) => (
        <div class={`timeline-item reveal reveal-delay-${idx + 1}`}>
          <!-- Icon Column -->
          <div class="timeline-icon-col">
            <div class="icon-wrapper glass">
              {item.type === 'work' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
              )}
              {item.type === 'education' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"></path><path d="M6 18.8v-4L2 13v6a1 1 0 0 0 1 1h3Z"></path><path d="M21.4 13.1v4.7a1 1 0 0 1-1.2.9h-4.2"></path></svg>
              )}
              {item.type === 'milestone' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
              )}
            </div>
            <div class="timeline-line"></div>
          </div>
          
          <!-- Content Card -->
          <div class="timeline-content glass">
            <span class="timeline-year">{item.year}</span>
            <h3 class="timeline-title">{item.title}</h3>
            <h4 class="timeline-subtitle">{item.subtitle}</h4>
            <p class="timeline-desc">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .bg-dim {
    background-color: var(--bg-secondary);
    transition: background-color var(--transition-normal);
  }

  .text-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Timeline */
  .timeline {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
  }

  .timeline-item:last-child .timeline-line {
    display: none;
  }

  /* Icon Col */
  .timeline-icon-col {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .icon-wrapper {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
    transition: background-color var(--transition-fast), border-color var(--transition-fast);
  }

  .timeline-item:hover .icon-wrapper {
    background-color: var(--primary-light);
    border-color: var(--primary);
  }

  .timeline-line {
    width: 2px;
    background-color: var(--border-color);
    flex-grow: 1;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  /* Content Card */
  .timeline-content {
    padding: 1.75rem 2rem;
    border-radius: var(--radius-lg);
    margin-bottom: 2.5rem;
    transition: transform var(--transition-fast), border-color var(--transition-fast);
  }

  .timeline-item:hover .timeline-content {
    transform: translateX(4px);
    border-color: var(--primary);
  }

  .timeline-year {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--primary);
    background-color: var(--primary-light);
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .timeline-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .timeline-subtitle {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .timeline-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .timeline-item {
      grid-template-columns: 50px 1fr;
      gap: 0.75rem;
    }
    
    .icon-wrapper {
      width: 36px;
      height: 36px;
    }

    .timeline-content {
      padding: 1.25rem 1.5rem;
    }
  }
</style>
